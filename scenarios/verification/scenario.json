{
  "name": "Верификация (SMS)",
  "scenario_version": "1",
  "gost_version": "ГОСТ 33465-2015",
  "timeout": 180,
  "description": "Первоначальная настройка УСВ через SMS: APN, адрес сервера, запрос UNIT_ID",
  "channels": ["sms"],
  "steps": [
    {
      "name": "Настройка GPRS/APN",
      "type": "send",
      "channel": "sms",
      "packet_type": "EGTS_GPRS_APN",
      "packet_file": "packets/platform/gprs_apn.hex",
"timeout": 120,
      "description": "Отправка настроек GPRS/APN (internet)"
    },
    {
      "name": "Подтверждение APN",
      "type": "expect",
      "channel": "sms",
      "timeout": 30,
      "checks": {
        "packet_type": 0,
        "ct": 1,
        "cid": 0
      },
      "description": "УСВ подтверждает приём настроек APN"
    },
    {
      "name": "Настройка адреса сервера",
      "type": "send",
      "channel": "sms",
      "packet_type": "EGTS_SERVER_ADDRESS",
      "packet_file": "packets/platform/server_address.hex",
      "timeout": 30,
      "description": "Отправка адреса и порта сервера (200.20.2.171:9090)"
    },
    {
      "name": "Подтверждение адреса",
      "type": "expect",
      "channel": "sms",
      "timeout": 30,
      "checks": {
        "packet_type": 0,
        "ct": 1,
        "cid": 0
      },
      "description": "УСВ подтверждает приём адреса сервера (cid=0 для теста)"
    },
    {
      "name": "Передача UNIT_ID",
      "type": "send",
      "channel": "sms",
      "packet_type": "EGTS_UNIT_ID",
      "packet_file": "packets/platform/unit_id.hex",
      "timeout": 30,
      "description": "Платформа передает УСВ идентификатор устройства"
    },
    {
      "name": "Подтверждение приема UNIT_ID",
      "type": "expect",
      "channel": "sms",
      "timeout": 30,
      "checks": {
        "packet_type": 0,
        "ct": 1,
        "cid": 0
      },

      "description": "УСВ возвращает UNIT_ID"
    }
  ]
}
