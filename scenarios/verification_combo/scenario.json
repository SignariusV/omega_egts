{
  "name": "Верификация (SMS) - COMBO",
  "scenario_version": "1",
  "gost_version": "ГОСТ 33465-2015",
  "timeout": 60,
  "description": "Тест 3 способов задания пакета: packet_file, packet_hex, build.packet",
  "channels": ["sms"],
  "variables": {
    "packet_id": 29,
    "record_id": 44,
    "service_type": 4,
    "recipient_service_type": 4
  },
  "steps": [
    {
      "name": "Настройка GPRS/APN (packet_file)",
      "type": "send",
      "channel": "sms",
      "packet_file": "packets/platform/gprs_apn.hex",
      "timeout": 60,
      "description": "Способ 1: packet_file -> читает из .hex файла"
    },
    {
      "name": "Подтверждение APN",
      "type": "expect",
      "channel": "sms",
      "packet_type": "CT_COMCONF",
      "timeout": 30,
      "checks": {
        "subrecord_type": "EGTS_SR_COMMAND_DATA",
        "ct": 1,
        "cid": 0
      },
      "description": "УСВ подтверждает приём настроек APN"
    },
    {
      "name": "Настройка адреса сервера (packet_hex)",
      "type": "send",
      "channel": "sms",
      "build": {
        "packet_hex": "0100000B002A001C0001AB23002B004004043320005001000000000000000000000204023230302E32302E322E3137313A393039305E55"
      },
      "timeout": 5,
      "description": "Способ 2: packet_hex -> строка hex напрямую"
    },
    {
      "name": "Подтверждение адреса",
      "type": "expect",
      "channel": "sms",
      "packet_type": "CT_COMCONF",
      "timeout": 5,
      "checks": {
        "subrecord_type": "EGTS_SR_COMMAND_DATA",
        "ct": 1,
        "cid": 1
      },
      "description": "УСВ подтверждает приём адреса сервера"
    },
    {
      "name": "Запрос UNIT_ID (build.packet)",
      "type": "send",
      "channel": "sms",
      "build": {
        "gost_version": "2015",
        "packet": {
          "packet_id": "{{packet_id}}",
          "packet_type": 1,
          "records": [
            {
              "record_id": "{{record_id}}",
              "service_type": "{{service_type}}",
              "recipient_service_type": "{{recipient_service_type}}",
              "rsod": true,
              "subrecords": [
                {
                  "subrecord_type": 51,
                  "data": {
                    "ct": 5,
                    "cct": 0,
                    "cid": 2,
                    "sid": 0,
                    "cd": {
                      "adr": 0,
                      "act": 0,
                      "sz": 0,
                      "ccd": 516,
                      "dt": "10.20.2.171:9090"
                    }
                  }
                }
              ]
            }
          ]
        }
      },
      "timeout": 5,
      "description": "Способ 3: build.packet -> динамическая генерация"
    },
    {
      "name": "Ответ с UNIT_ID",
      "type": "expect",
      "channel": "sms",
      "packet_type": "CT_COMCONF",
      "timeout": 5,
      "checks": {
        "subrecord_type": "EGTS_SR_COMMAND_DATA",
        "ct": 1,
        "cid": 2
      },
      "capture": {
        "unit_id": "data"
      },
      "description": "УСВ возвращает UNIT_ID"
    }
  ]
}