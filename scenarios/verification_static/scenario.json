{
  "name": "Верификация (SMS)",
  "scenario_version": "1",
  "gost_version": "ГОСТ 33465-2015",
  "timeout": 60,
  "description": "Первоначальная настройка УСВ через SMS: APN, адрес сервера, запрос UNIT_ID",
  "channels": ["sms"],
  "steps": [
    {
      "name": "Настройка GPRS/APN",
      "type": "send",
      "channel": "sms",
      "build": {
        "gost_version": "2015",
        "packet": {
          "packet_id": 27,
          "packet_type": 1,
          "records": [
            {
              "record_id": 1,
              "service_type": 4,
              "recipient_service_type": 4,
              "rsod": true,
              "subrecords": [
                {
                  "subrecord_type": 51,
                  "data": {
                    "ct": 5,
                    "cct": 0,
                    "cid": 0,
                    "sid": 0,
                    "cd": {
                      "adr": 0,
                      "act": 2,
                      "sz": 0,
                      "ccd": 515,
                      "dt": "internet"
                    }
                  }
                }
              ]
            }
          ]
        }
      },
      "timeout": 60,
      "description": "Отправка настроек GPRS/APN (internet)"
    },
    {
      "name": "Подтверждение APN",
      "type": "expect",
      "channel": "sms",
      "packet_type": "CT_COMCONF",
      "timeout": 30,
      "checks": {
        "subrecord_type": "EGTS_SR_COMMAND_DATA",
        "ct": 1,
        "cid": 0
      },
      "description": "УСВ подтверждает приём настроек APN"
    },
    {
      "name": "Настройка адреса сервера",
      "type": "send",
      "channel": "sms",
      "build": {
        "gost_version": "2015",
        "packet": {
          "packet_id": 28,
          "packet_type": 1,
          "records": [
            {
              "record_id": 2,
              "service_type": 4,
              "recipient_service_type": 4,
              "rsod": true,
              "subrecords": [
                {
                  "subrecord_type": 51,
                  "data": {
                    "ct": 5,
                    "cct": 0,
                    "cid": 1,
                    "sid": 0,
                    "cd": {
                      "adr": 0,
                      "act": 2,
                      "sz": 0,
                      "ccd": 516,
                      "dt": "200.20.2.171:9090"
                    }
                  }
                }
              ]
            }
          ]
        }
      },
      "timeout": 5,
      "description": "Отправка адреса и порта сервера (200.20.2.171:9090)"
    },
    {
      "name": "Подтверждение адреса",
      "type": "expect",
      "channel": "sms",
      "packet_type": "CT_COMCONF",
      "timeout": 5,
      "checks": {
        "subrecord_type": "EGTS_SR_COMMAND_DATA",
        "ct": 1,
        "cid": 1
      },
      "description": "УСВ подтверждает приём адреса сервера"
    },
    {
      "name": "Запрос UNIT_ID",
      "type": "send",
      "channel": "sms",
      "build": {
        "gost_version": "2015",
        "packet": {
          "packet_id": 29,
          "packet_type": 1,
          "records": [
            {
              "record_id": 3,
              "service_type": 4,
              "recipient_service_type": 4,
              "rsod": true,
              "subrecords": [
                {
                  "subrecord_type": 51,
                  "data": {
                    "ct": 5,
                    "cct": 0,
                    "cid": 2,
                    "sid": 0,
                    "cd": {
                      "adr": 0,
                      "act": 4,
                      "sz": 0,
                      "ccd": 0,
                      "dt": "\x00\x01"
                    }
                  }
                }
              ]
            }
          ]
        }
      },
      "timeout": 5,
      "description": "Запрос идентификатора устройства"
    },
    {
      "name": "Ответ с UNIT_ID",
      "type": "expect",
      "channel": "sms",
      "packet_type": "CT_COMCONF",
      "timeout": 5,
      "checks": {
        "subrecord_type": "EGTS_SR_COMMAND_DATA",
        "ct": 1,
        "cid": 2
      },
      "capture": {
        "unit_id": "data"
      },
      "description": "УСВ возвращает UNIT_ID"
    }
  ]
}
