**Валидация сценария:**
```python
def validate_scenario(scenario: dict) -> tuple[bool, list[str]]:
    """Проверка структуры сценария."""
    errors = []

    # Обязательные поля
    required_fields = ["name", "version", "steps"]
    for field in required_fields:
        if field not in scenario:
            errors.append(f"Отсутствует обязательное поле: {field}")

    # Проверка шагов
    if "steps" in scenario:
        for i, step in enumerate(scenario["steps"]):
            if "type" not in step:
                errors.append(f"Шаг {i}: отсутствует поле 'type'")
            if step.get("type") not in ["expect", "send", "delay"]:
                errors.append(f"Шаг {i}: неизвестный тип '{step.get('type')}'")

    return len(errors) == 0, errors
```

