class ConnectionTab(QWidget):
    def __init__(self, engine: CoreEngine, bridge: EventBridge):
        super().__init__()
        self.engine = engine
        self.bridge = bridge
        self._connect_signals()

    def _connect_signals(self):
        # Подписка на события EventBus через bridge
        self.bridge.server_started.connect(self._on_server_started)
        self.bridge.server_stopped.connect(self._on_server_stopped)
        self.bridge.cmw_connected.connect(self._on_cmw_connected)

        # Подключение кнопок
        self.btn_start.clicked.connect(self._start_server)
        self.btn_stop.clicked.connect(self._stop_server)

    async def _start_server(self):
        """Запуск сервера."""
        port = int(self.port_input.text())
        gost = self.gost_combo.currentText()
        cmw_ip = self.cmw_ip_input.text()

        # Обновление конфигурации
        self.engine.config.tcp_port = port
        self.engine.config.gost_version = gost
        self.engine.config.cmw_ip = cmw_ip

        # Запуск через engine
        await self.engine.start()

    async def _stop_server(self):
        """Остановка сервера."""
        # Подтверждение
        reply = QMessageBox.question(
            self, "Подтверждение",
            "Остановить сервер?",
            QMessageBox.Yes | QMessageBox.No
        )

        if reply == QMessageBox.Yes:
            await self.engine.stop()

    def _on_server_started(self, data: dict):
        """Обработчик события server.started."""
        self.status_label.setText("🟢 СЕРВЕР ЗАПУЩЕН")
        self.btn_start.setEnabled(False)
        self.btn_stop.setEnabled(True)
        self._lock_config(True)

    def _on_server_stopped(self, data: dict):
        """Обработчик события server.stopped."""
        self.status_label.setText("🔴 СЕРВЕР ОСТАНОВЛЕН")
        self.btn_start.setEnabled(True)
        self.btn_stop.setEnabled(False)
        self._lock_config(False)
