### 9.3. Обновление UI через EventBus

```python
# gui/tabs/scenarios_tab.py
class ScenariosTab(QWidget):
    def __init__(self, engine: CoreEngine, bridge: EventBridge):
        super().__init__()
        self.bridge = bridge
        self.packets: list[dict] = []
        self._connect_events()

    def _connect_events(self):
        # Подписка на события
        self.bridge.packet_processed.connect(self._on_packet)
        self.bridge.scenario_step.connect(self._on_scenario_step)
        self.bridge.scenario_started.connect(self._on_scenario_started)
        self.bridge.scenario_finished.connect(self._on_scenario_finished)

    def _on_packet(self, data: dict):
        """Обработка нового пакета."""
        ctx = data["ctx"]

        # Добавление в список
        packet_info = {
            "time": datetime.now().strftime("%H:%M:%S.%f")[:-3],
            "direction": "RX" if ctx.channel == "tcp" else "TX",
            "pid": ctx.parsed.get("PID") if ctx.parsed else "-",
            "rn": ctx.parsed.get("RN") if ctx.parsed and ctx.parsed.get("records") else "-",
            "size": len(ctx.raw),
            "service": self._get_service_name(ctx.parsed) if ctx.parsed else "-",
            "raw": ctx.raw.hex()
        }

        self.packets.append(packet_info)

        # Обновление таблицы
        row = self.packet_table.rowCount()
        self.packet_table.insertRow(row)
        self.packet_table.setItem(row, 0, QTableWidgetItem(packet_info["time"]))
        self.packet_table.setItem(row, 1, QTableWidgetItem(
            "▶" if packet_info["direction"] == "RX" else "◀" + packet_info["direction"]
        ))
        self.packet_table.setItem(row, 2, QTableWidgetItem(str(packet_info["pid"])))
        # ... остальные колонки

        # Автопрокрутка
        if self.auto_scroll_check.isChecked():
            self.packet_table.scrollToBottom()

    def _on_scenario_step(self, data: dict):
        """Обновление статуса шага сценария."""
        step_name = data["step"]
        status = data["status"]

        # Поиск строки с шагом
        for row in range(self.step_table.rowCount()):
            if self.step_table.item(row, 1).text() == step_name:
                # Обновление статуса
                status_item = QTableWidgetItem(self._get_status_icon(status))
                status_item.setToolTip(status)
                self.step_table.setItem(row, 3, status_item)

                # Подсветка
                color = self._get_status_color(status)
                for col in range(4):
                    self.step_table.item(row, col).setBackground(color)
                break

        # Обновление прогресса
        self._update_progress()
